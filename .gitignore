# PA-GNN .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environment
venv/
env/
.env

# Data
# We ignore the raw and processed data because they are massive (Gigabytes of images/graphs)
data/raw/
data/processed/
# Note: data/splits/ is NOT ignored because we want to version control the train/test text files for reproducibility

# Model Checkpoints (Heavy binary .pth files)
checkpoints/*.pth
checkpoints/*.pt

# Results and Logs
results/tables/*.csv
results/figures/*.png
results/figures/*.pdf
results/logs/

# OS/IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
.ipynb_checkpoints/
